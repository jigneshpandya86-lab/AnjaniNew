rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // App metadata (order ID counter) — authenticated reads/writes only
    match /meta/{docId} {
      allow read, write: if request.auth != null;
    }

    // Customers — authenticated users only
    match /customers/{customerId} {
      allow read, write: if request.auth != null;
    }

    // Orders — authenticated users only
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    // Payments — authenticated users only
    match /payments/{paymentId} {
      allow read, write: if request.auth != null;
    }

    // Leads — authenticated users only
    match /leads/{leadId} {
      allow read, write: if request.auth != null;
    }

    // Stock — authenticated users only
    match /stock/{stockId} {
      allow read, write: if request.auth != null;
    }

    // Archived orders — authenticated users only
    match /archived_orders/{orderId} {
      allow read, write: if request.auth != null;
    }
  }
}
